generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  COMPANY_ADMIN
  QUALITY_CONTROLLER
  AGENT
  BUSINESS_OWNER
  CLIENT
}

enum Civility {
  MONSIEUR
  MADAME
}

enum ContractType {
  CDD
  CDI
  APPRENTI
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum UserStatus {
  INVITED
  ACTIVE
  DISABLED
  ARCHIVED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
  FAILED
}

enum AssignmentStatus {
  ACTIVE
  PLANNED
  ENDED
  ARCHIVED
}

enum ControlType {
  PROGRAMME
  INOPINE
}

enum ControlStatus {
  BROUILLON
  EN_COURS
  EN_ATTENTE_QCM
  A_VALIDER
  VALIDE
  CLOTURE
  ANNULE
}

enum Severity {
  MINEURE
  MAJEURE
  CRITIQUE
}

enum Requirement {
  NONE
  OPTIONAL
  REQUIRED
}

enum ControlPointStatus {
  CONFORME
  NON_CONFORME
  SANS_OBJET
}

enum ControlImpactLevel {
  VERT
  JAUNE
  ORANGE
  ROUGE
  CRITIQUE
}

enum NonConformityStatus {
  OUVERTE
  EN_COURS
  CORRIGEE
  VALIDEE
  REFUSEE
  CLOTUREE
}

enum EvidenceType {
  PHOTO_CAPTURE
  PHOTO_UPLOAD
  FILE
  VOICE_COMMENT
  SIGNATURE
}

enum DocumentScope {
  AGENT
  ENTREPRISE
  CLIENT
  SITE
  CONSIGNE_SITE
  RAPPORT_AUDIT
  JUSTIFICATIF_REGLEMENTAIRE
}

enum DocumentStatus {
  VALIDE
  EN_ATTENTE_VALIDATION
  MANQUANT
  EXPIRANT_BIENTOT
  EXPIRE
  REFUSE
  ARCHIVE
}

enum FileVisibility {
  INTERNE
  AGENT
  CLIENT_AUTORISE
  DIRECTION
  PUBLIC_CONTROLE
}

enum QcmType {
  OPS
  LIGNE_METIER
  CLIENT
}

enum QcmBankType {
  ENTREPRISE
  METIER
  CLIENT_SITE
}

enum QuestionType {
  CHOIX_UNIQUE
  CHOIX_MULTIPLE
}

enum QcmDifficulty {
  FACILE
  MOYEN
  DIFFICILE
}

enum QcmSessionStatus {
  ENVOYE
  EN_COURS
  TERMINE
  INTERROMPU
  EXPIRE
  ANNULE
}

enum QcmLaunchTiming {
  PENDANT_CONTROLE
  FIN_CONTROLE
  APRES_CONTROLE
}

enum PlanningStatus {
  DEMANDE
  ACCEPTE
  PLANIFIE
  REALISE
  CLOTURE
  REFUSE
  REPORTE
}

enum NotificationType {
  QCM_A_REALISER
  DOCUMENT_EXPIRANT
  DOCUMENT_MANQUANT
  NON_CONFORMITE_VALIDEE
  CONTROLE_PLANIFIE
  DEMANDE_CONTROLE
  RAPPORT_DISPONIBLE
  PREVENTION_VALIDEE
  ALERTE_CRITIQUE
}

enum ReportType {
  COMPLET_INTERNE
  SIMPLIFIE_CLIENT
  RAPPORT_AGENT
  RAPPORT_DIRECTION
  SYNTHESE_MENSUELLE
}

enum ReportVisibility {
  INTERNE
  AGENT
  DIRECTION
  CLIENT_SIMPLIFIE
  CLIENT_COMPLET_APPROUVE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  ARCHIVE
  LOGIN
  LOGOUT
  EXPORT
  VALIDATE
  CLOSE
  SYNC
}

enum SyncStatus {
  PENDING
  APPLIED
  REJECTED
}

model Company {
  id                       String                  @id @default(cuid())
  name                     String
  slug                     String                  @unique
  logoUrl                  String?
  siret                    String?
  cnapsAuthorizationNumber String?
  address                  String?
  phone                    String?
  website                  String?
  legalNotice              String?
  status                   CompanyStatus           @default(ACTIVE)
  settings                 Json?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  archivedAt               DateTime?
  users                    User[]
  clients                  Client[]
  sites                    Site[]
  agents                   Agent[]
  assignments              Assignment[]
  controlItemDefinitions   ControlItemDefinition[]
  controls                 Control[]
  nonConformities          NonConformity[]
  evidences                Evidence[]
  documents                Document[]
  qcms                     Qcm[]
  qcmBanks                 QcmBank[]
  qcmSessions              QcmSession[]
  qcmSettings              QcmSetting[]
  planningRequests         PlanningRequest[]
  notifications            Notification[]
  reports                  Report[]
  preventionMessages       PreventionMessage[]
  monthlySummaries         MonthlySummary[]
  aiInsights               AiInsight[]
  auditLogs                AuditLog[]
  userInvitations          UserInvitation[]
  reportTemplates          ReportTemplate[]
  syncEvents               SyncEvent[]
  controlTemplates         ControlTemplate[]
  controlSessions          ControlSession[]
  correctiveActions        CorrectiveAction[]
  controlReports           ControlReport[]
  controlEvidences         ControlEvidence[]
  controlSignatures        ControlSignature[]
}

model User {
  id                         String                       @id @default(cuid())
  companyId                  String?
  email                      String                       @unique
  passwordHash               String
  firstName                  String
  lastName                   String
  role                       Role
  status                     UserStatus                   @default(ACTIVE)
  phone                      String?
  lastLoginAt                DateTime?
  emailVerifiedAt            DateTime?
  preferences                Json?
  createdAt                  DateTime                     @default(now())
  updatedAt                  DateTime                     @updatedAt
  archivedAt                 DateTime?
  company                    Company?                     @relation(fields: [companyId], references: [id], onDelete: Restrict)
  agentProfile               Agent?
  controlsAsController       Control[]                    @relation("ControlController")
  controlsValidated          Control[]                    @relation("ControlValidator")
  nonConformitiesValidated   NonConformity[]              @relation("NonConformityValidator")
  evidenceUploaded           Evidence[]                   @relation("EvidenceUploader")
  documentsValidated         Document[]                   @relation("DocumentValidator")
  qcmSessionsSent            QcmSession[]                 @relation("QcmSessionSender")
  planningRequestsCreated    PlanningRequest[]            @relation("PlanningRequester")
  planningRequestsControlled PlanningRequest[]            @relation("PlanningController")
  notifications              Notification[]
  reportsGenerated           Report[]                     @relation("ReportGenerator")
  preventionAcknowledgements PreventionAcknowledgement[]
  auditLogs                  AuditLog[]
  invitationsSent            UserInvitation[]             @relation("InvitationInviter")
  invitationsAccepted        UserInvitation[]             @relation("InvitationAcceptedUser")
}

model UserInvitation {
  id             String           @id @default(cuid())
  companyId      String?
  email          String
  firstName      String
  lastName       String
  role           Role
  tokenHash      String           @unique
  status         InvitationStatus @default(PENDING)
  expiresAt      DateTime
  sentAt         DateTime?
  acceptedAt     DateTime?
  invitedById    String?
  createdUserId  String?
  lastEmailError String?
  metadata       Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  company        Company?         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invitedBy      User?            @relation("InvitationInviter", fields: [invitedById], references: [id], onDelete: SetNull)
  createdUser    User?            @relation("InvitationAcceptedUser", fields: [createdUserId], references: [id], onDelete: SetNull)

  @@index([companyId, status, createdAt])
  @@index([email])
}

model Client {
  id              String            @id @default(cuid())
  companyId       String
  name            String
  reference       String
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  address         String?
  settings        Json?
  active          Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  archivedAt      DateTime?
  company         Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sites           Site[]
  assignments     Assignment[]
  planningRequests PlanningRequest[]
  controls        Control[]
  nonConformities NonConformity[]
  documents       Document[]
  qcms            Qcm[]
  qcmBanks        QcmBank[]
  dynamicControlSessions ControlSession[]

  @@unique([companyId, reference])
  @@index([companyId])
}

model Site {
  id              String            @id @default(cuid())
  companyId       String
  clientId        String
  name            String
  reference       String
  address         String
  latitude        Float?
  longitude       Float?
  timezone        String            @default("Europe/Paris")
  riskLevel       String?
  active          Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  archivedAt      DateTime?
  company         Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client          Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignments     Assignment[]
  planningRequests PlanningRequest[]
  controls        Control[]
  nonConformities NonConformity[]
  documents       Document[]
  qcms            Qcm[]
  qcmBanks        QcmBank[]
  dynamicControlSessions ControlSession[]

  @@unique([companyId, reference])
  @@index([companyId, clientId])
}

model Agent {
  id                        String           @id @default(cuid())
  companyId                 String
  userId                    String?          @unique
  photoUrl                  String?
  civility                  Civility?
  matricule                 String
  firstName                 String
  lastName                  String
  birthDate                 DateTime?
  birthPlace                String?
  email                     String?
  phone                     String?
  professionalCardNumber    String?
  professionalCardExpiresAt DateTime?
  sstExpiresAt              DateTime?
  ssiapExpiresAt            DateTime?
  diplomas                  String[]         @default([])
  eligibleJobTitles         String[]         @default([])
  contractType              ContractType?
  hiredAt                   DateTime?
  qualityScore              Float            @default(0)
  active                    Boolean          @default(true)
  notes                     String?
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt
  archivedAt                DateTime?
  company                   Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user                      User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  assignments               Assignment[]
  planningRequests          PlanningRequest[]
  controls                  Control[]
  dynamicControlSessions    ControlSession[]
  nonConformities           NonConformity[]
  documents                 Document[]
  qcmSessions               QcmSession[]

  @@unique([companyId, matricule])
  @@index([companyId])
}

model Assignment {
  id             String           @id @default(cuid())
  companyId      String
  agentId        String
  clientId       String
  siteId         String
  jobTitle       String
  customJobTitle String?
  startsAt       DateTime
  endsAt         DateTime?
  status         AssignmentStatus @default(ACTIVE)
  history        Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  company        Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  agent          Agent            @relation(fields: [agentId], references: [id], onDelete: Cascade)
  client         Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  site           Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([companyId, agentId, siteId])
}

model ControlItemDefinition {
  id                   String              @id @default(cuid())
  companyId            String
  label                String
  category             String
  coefficient          Float               @default(1)
  severity             Severity            @default(MINEURE)
  color                String              @default("#f59e0b")
  correctionDelayHours Int?
  blocking             Boolean             @default(false)
  recommendedAction    String?
  autoNotify           Boolean             @default(false)
  clientVisible        Boolean             @default(true)
  impactsGlobalScore   Boolean             @default(true)
  photoRequirement     Requirement         @default(OPTIONAL)
  fileRequirement      Requirement         @default(NONE)
  voiceRequirement     Requirement         @default(OPTIONAL)
  active               Boolean             @default(true)
  sortOrder            Int                 @default(0)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  company              Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  itemResults          ControlItemResult[]
  nonConformities      NonConformity[]

  @@index([companyId, category])
}

model Control {
  id                String              @id @default(cuid())
  companyId         String
  type              ControlType
  status            ControlStatus       @default(BROUILLON)
  plannedAt         DateTime?
  startedAt         DateTime            @default(now())
  completedAt       DateTime?
  controllerId      String
  agentId           String
  clientId          String
  siteId            String
  latitude          Float?
  longitude         Float?
  detectedAddress   String?
  globalScore       Float               @default(0)
  observations      String?
  agentSignature    String?
  controllerSignature String?
  validatedAt       DateTime?
  validatedById     String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  company           Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  controller        User                @relation("ControlController", fields: [controllerId], references: [id], onDelete: Restrict)
  validatedBy       User?               @relation("ControlValidator", fields: [validatedById], references: [id], onDelete: SetNull)
  agent             Agent               @relation(fields: [agentId], references: [id], onDelete: Restrict)
  client            Client              @relation(fields: [clientId], references: [id], onDelete: Restrict)
  site              Site                @relation(fields: [siteId], references: [id], onDelete: Restrict)
  itemResults       ControlItemResult[]
  nonConformities   NonConformity[]
  qcmSessions       QcmSession[]
  reports           Report[]
  dynamicSession    ControlSession?

  @@index([companyId, startedAt])
  @@index([companyId, status])
}

model ControlTemplate {
  id          String             @id @default(cuid())
  companyId   String
  title       String
  description String?
  version     Int                @default(1)
  active      Boolean            @default(true)
  reportRules Json?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  archivedAt  DateTime?
  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  criteria    ControlCriterion[]
  sessions    ControlSession[]

  @@index([companyId, active])
}

model ControlCriterion {
  id          String              @id @default(cuid())
  companyId   String
  templateId  String
  label       String
  description String?
  coefficient Float               @default(1)
  sortOrder   Int                 @default(0)
  active      Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  archivedAt  DateTime?
  template    ControlTemplate     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  points      ControlPoint[]
  results     ControlCriterionResult[]
  pointResults ControlPointResult[]

  @@index([companyId, templateId, sortOrder])
}

model ControlPoint {
  id                       String                       @id @default(cuid())
  companyId                String
  criterionId              String
  label                    String
  description              String?
  coefficient              Float                        @default(1)
  defaultSeverity          Severity                     @default(MINEURE)
  blocking                 Boolean                      @default(false)
  defaultCorrectiveAction  String?
  defaultCorrectionDelayHours Int?
  photoRequirement         Requirement                  @default(OPTIONAL)
  fileRequirement          Requirement                  @default(NONE)
  voiceRequirement         Requirement                  @default(OPTIONAL)
  visibleInAgentReport     Boolean                      @default(true)
  visibleInDirectionReport Boolean                      @default(true)
  visibleInClientReport    Boolean                      @default(true)
  sortOrder                Int                          @default(0)
  active                   Boolean                      @default(true)
  createdAt                DateTime                     @default(now())
  updatedAt                DateTime                     @updatedAt
  archivedAt               DateTime?
  criterion                ControlCriterion             @relation(fields: [criterionId], references: [id], onDelete: Cascade)
  responseOptions          ControlPointResponseOption[]
  results                  ControlPointResult[]

  @@index([companyId, criterionId, sortOrder])
}

model ControlPointResponseOption {
  id                       String             @id @default(cuid())
  companyId                String
  pointId                  String
  status                   ControlPointStatus
  label                    String
  impactLevel              ControlImpactLevel @default(VERT)
  severity                 Severity           @default(MINEURE)
  score                    Int                @default(100)
  affectsScore             Boolean            @default(true)
  affectsCompliance        Boolean            @default(true)
  correctiveAction         String?
  correctionDelayHours     Int?
  blocking                 Boolean            @default(false)
  notificationRequired     Boolean            @default(false)
  visibleInAgentReport     Boolean            @default(true)
  visibleInDirectionReport Boolean            @default(true)
  visibleInClientReport    Boolean            @default(true)
  sortOrder                Int                @default(0)
  active                   Boolean            @default(true)
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  archivedAt               DateTime?
  point                    ControlPoint       @relation(fields: [pointId], references: [id], onDelete: Cascade)
  results                  ControlPointResult[]

  @@index([companyId, pointId, status])
}

model ControlSession {
  id              String                   @id @default(cuid())
  companyId       String
  controlId       String?                  @unique
  templateId      String
  agentId         String
  clientId        String
  siteId          String
  type            ControlType              @default(INOPINE)
  status          ControlStatus            @default(BROUILLON)
  selectedCriterionIds String[]
  globalScore     Float                    @default(0)
  complianceLevel String?
  startedAt       DateTime                 @default(now())
  completedAt     DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  archivedAt      DateTime?
  metadata        Json?
  company         Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  control         Control?                 @relation(fields: [controlId], references: [id], onDelete: SetNull)
  template        ControlTemplate          @relation(fields: [templateId], references: [id], onDelete: Restrict)
  agent           Agent                    @relation(fields: [agentId], references: [id], onDelete: Restrict)
  client          Client                   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  site            Site                     @relation(fields: [siteId], references: [id], onDelete: Restrict)
  criterionResults ControlCriterionResult[]
  pointResults    ControlPointResult[]
  correctiveActions CorrectiveAction[]
  reports         ControlReport[]
  evidences       ControlEvidence[]
  signatures      ControlSignature[]

  @@index([companyId, status, startedAt])
  @@index([agentId, startedAt])
  @@index([siteId, startedAt])
}

model ControlCriterionResult {
  id          String           @id @default(cuid())
  sessionId   String
  criterionId String
  score       Float            @default(0)
  comment     String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  session     ControlSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  criterion   ControlCriterion @relation(fields: [criterionId], references: [id], onDelete: Restrict)
  pointResults ControlPointResult[]

  @@unique([sessionId, criterionId])
}

model ControlPointResult {
  id                 String                     @id @default(cuid())
  sessionId          String
  criterionResultId  String?
  criterionId        String
  pointId            String
  responseOptionId   String
  status             ControlPointStatus
  score              Int
  impactLevel        ControlImpactLevel
  severity           Severity
  blockingTriggered  Boolean                    @default(false)
  observation        String?
  correctiveAction   String?
  correctionDelayHours Int?
  reportVisibility   Json?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  session            ControlSession             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  criterionResult    ControlCriterionResult?    @relation(fields: [criterionResultId], references: [id], onDelete: SetNull)
  criterion          ControlCriterion           @relation(fields: [criterionId], references: [id], onDelete: Restrict)
  point              ControlPoint               @relation(fields: [pointId], references: [id], onDelete: Restrict)
  responseOption     ControlPointResponseOption @relation(fields: [responseOptionId], references: [id], onDelete: Restrict)
  nonConformityLink  ControlNonConformityLink?
  evidences          ControlEvidence[]

  @@unique([sessionId, pointId])
  @@index([sessionId, status])
}

model ControlNonConformityLink {
  id              String             @id @default(cuid())
  pointResultId   String             @unique
  nonConformityId String
  createdAt       DateTime           @default(now())
  pointResult     ControlPointResult @relation(fields: [pointResultId], references: [id], onDelete: Cascade)
  nonConformity   NonConformity      @relation(fields: [nonConformityId], references: [id], onDelete: Cascade)
}

model CorrectiveAction {
  id              String       @id @default(cuid())
  companyId       String
  sessionId       String?
  nonConformityId String?
  title           String
  description     String?
  severity        Severity     @default(MINEURE)
  dueAt           DateTime?
  status          NonConformityStatus @default(OUVERTE)
  assignedToId    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  closedAt        DateTime?
  archivedAt      DateTime?
  company         Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  session         ControlSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  nonConformity   NonConformity? @relation(fields: [nonConformityId], references: [id], onDelete: SetNull)

  @@index([companyId, status, dueAt])
}

model ControlReport {
  id          String        @id @default(cuid())
  companyId   String
  sessionId   String
  type        ReportType
  title       String
  fileUrl     String?
  payload     Json?
  createdAt   DateTime      @default(now())
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  session     ControlSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([companyId, type, createdAt])
}

model ControlEvidence {
  id             String       @id @default(cuid())
  companyId      String
  sessionId      String
  pointResultId  String?
  type           EvidenceType
  fileName       String?
  fileUrl        String?
  mimeType       String?
  required       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  company        Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  session        ControlSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  pointResult    ControlPointResult? @relation(fields: [pointResultId], references: [id], onDelete: SetNull)

  @@index([companyId, sessionId])
}

model ControlSignature {
  id          String       @id @default(cuid())
  companyId   String
  sessionId   String
  role        String
  signerName  String?
  dataUrl     String
  signedAt    DateTime     @default(now())
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  session     ControlSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([companyId, sessionId])
}

model ControlItemResult {
  id               String                @id @default(cuid())
  controlId        String
  itemDefinitionId String
  score            Int
  compliant        Boolean               @default(true)
  comment          String?
  blockingTriggered Boolean              @default(false)
  evidenceRequired Boolean               @default(false)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  control          Control               @relation(fields: [controlId], references: [id], onDelete: Cascade)
  itemDefinition   ControlItemDefinition @relation(fields: [itemDefinitionId], references: [id], onDelete: Restrict)
  evidences        Evidence[]
  nonConformity    NonConformity?

  @@index([controlId])
}

model NonConformity {
  id               String                  @id @default(cuid())
  companyId        String
  title            String
  description      String
  severity         Severity
  status           NonConformityStatus     @default(OUVERTE)
  itemDefinitionId String?
  itemResultId     String?                 @unique
  agentId          String?
  clientId         String
  siteId           String
  controlId        String?
  dueAt            DateTime?
  delayLabel       String?
  internalOnly     Boolean                 @default(true)
  validatedAt      DateTime?
  validatedById    String?
  closedAt         DateTime?
  agentSignature   String?
  controllerSignature String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  company          Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  itemDefinition   ControlItemDefinition?  @relation(fields: [itemDefinitionId], references: [id], onDelete: SetNull)
  itemResult       ControlItemResult?      @relation(fields: [itemResultId], references: [id], onDelete: SetNull)
  agent            Agent?                  @relation(fields: [agentId], references: [id], onDelete: SetNull)
  client           Client                  @relation(fields: [clientId], references: [id], onDelete: Restrict)
  site             Site                    @relation(fields: [siteId], references: [id], onDelete: Restrict)
  control          Control?                @relation(fields: [controlId], references: [id], onDelete: SetNull)
  validatedBy      User?                   @relation("NonConformityValidator", fields: [validatedById], references: [id], onDelete: SetNull)
  evidences        Evidence[]
  comments         NonConformityComment[]
  controlLinks     ControlNonConformityLink[]
  correctiveActions CorrectiveAction[]

  @@index([companyId, severity])
  @@index([companyId, status])
}

model NonConformityComment {
  id              String         @id @default(cuid())
  nonConformityId String
  authorName      String
  body            String
  internal        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  nonConformity   NonConformity  @relation(fields: [nonConformityId], references: [id], onDelete: Cascade)
}

model Evidence {
  id                  String             @id @default(cuid())
  companyId           String
  nonConformityId     String?
  controlItemResultId String?
  type                EvidenceType
  fileName            String?
  fileUrl             String?
  mimeType            String?
  size                Int?
  voiceTranscription  String?
  metadata            Json?
  uploadedById        String?
  createdAt           DateTime           @default(now())
  company             Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  nonConformity       NonConformity?     @relation(fields: [nonConformityId], references: [id], onDelete: Cascade)
  controlItemResult   ControlItemResult? @relation(fields: [controlItemResultId], references: [id], onDelete: Cascade)
  uploadedBy          User?              @relation("EvidenceUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([companyId])
}

model Document {
  id            String         @id @default(cuid())
  companyId     String
  scope         DocumentScope
  status        DocumentStatus @default(EN_ATTENTE_VALIDATION)
  title         String
  category      String
  description   String?
  fileUrl       String?
  fileName      String?
  mimeType      String?
  expiresAt     DateTime?
  validatedAt   DateTime?
  validatedById String?
  agentId       String?
  clientId      String?
  siteId        String?
  visibility    FileVisibility @default(INTERNE)
  allowedRoles  Role[]
  tags          String[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  archivedAt    DateTime?
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  validatedBy   User?          @relation("DocumentValidator", fields: [validatedById], references: [id], onDelete: SetNull)
  agent         Agent?         @relation(fields: [agentId], references: [id], onDelete: SetNull)
  client        Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  site          Site?          @relation(fields: [siteId], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([companyId, scope])
}

model Qcm {
  id                  String        @id @default(cuid())
  companyId           String
  type                QcmType
  title               String
  category            String
  coefficient         Int
  clientId            String?
  siteId              String?
  jobTitle            String?
  minimumScore        Int           @default(80)
  maxQuestionsPerItem Int           @default(10)
  active              Boolean       @default(true)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  company             Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client              Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  site                Site?         @relation(fields: [siteId], references: [id], onDelete: SetNull)
  questions           QcmQuestion[]
  sessions            QcmSession[]

  @@index([companyId, type])
}

model QcmBank {
  id                     String           @id @default(cuid())
  companyId              String
  type                   QcmBankType
  title                  String
  description            String?
  coefficient            Int
  qualification          String?
  clientId               String?
  siteId                 String?
  questionCountPerSession Int             @default(10)
  timePerQuestionSeconds Int              @default(60)
  passingScore           Int              @default(80)
  active                 Boolean          @default(true)
  guidanceTitle          String?
  guidanceBody           String?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  archivedAt             DateTime?
  company                Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client                 Client?          @relation(fields: [clientId], references: [id], onDelete: SetNull)
  site                   Site?            @relation(fields: [siteId], references: [id], onDelete: SetNull)
  questions              QcmQuestion[]    @relation("QcmBankQuestions")
  sessions               QcmSession[]     @relation("QcmBankSessions")

  @@index([companyId, type])
  @@index([companyId, qualification])
  @@index([companyId, clientId, siteId])
}

model QcmQuestion {
  id          String       @id @default(cuid())
  companyId   String?
  qcmId       String?
  bankId      String?
  label       String
  type        QuestionType @default(CHOIX_UNIQUE)
  category    String?
  qualification String?
  clientId    String?
  siteId      String?
  sortOrder   Int          @default(0)
  points      Int          @default(1)
  explanation String?
  active      Boolean      @default(true)
  difficulty  QcmDifficulty?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  qcm         Qcm?         @relation(fields: [qcmId], references: [id], onDelete: Cascade)
  bank        QcmBank?     @relation("QcmBankQuestions", fields: [bankId], references: [id], onDelete: Cascade)
  choices     QcmChoice[]
  answers     QcmAnswer[]

  @@index([companyId, bankId, active])
}

model QcmChoice {
  id         String      @id @default(cuid())
  questionId String
  label      String
  isCorrect  Boolean     @default(false)
  question   QcmQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model QcmSession {
  id          String           @id @default(cuid())
  companyId   String
  qcmId       String?
  bankId      String?
  controlId   String?
  agentId     String
  clientId    String?
  siteId      String?
  qualification String?
  launchTiming QcmLaunchTiming?
  availableAt DateTime?
  status      QcmSessionStatus @default(ENVOYE)
  score       Float?
  passed      Boolean?
  weightedScore Float?
  questionIds String[]         @default([])
  currentQuestionIndex Int     @default(0)
  resumeAllowed Boolean        @default(false)
  resumeCount  Int             @default(0)
  interruptionReason String?
  startedAt   DateTime?
  interruptedAt DateTime?
  completedAt DateTime?
  sentById    String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  qcm         Qcm?             @relation(fields: [qcmId], references: [id], onDelete: Cascade)
  bank        QcmBank?         @relation("QcmBankSessions", fields: [bankId], references: [id], onDelete: Cascade)
  control     Control?         @relation(fields: [controlId], references: [id], onDelete: SetNull)
  agent       Agent            @relation(fields: [agentId], references: [id], onDelete: Cascade)
  sentBy      User?            @relation("QcmSessionSender", fields: [sentById], references: [id], onDelete: SetNull)
  answers     QcmAnswer[]
  result      QcmResult?
  interruptions QcmInterruption[]

  @@index([companyId, status])
  @@index([agentId])
  @@index([companyId, controlId])
}

model QcmAnswer {
  id                String      @id @default(cuid())
  sessionId         String
  questionId        String
  selectedChoiceIds String[]
  isCorrect         Boolean     @default(false)
  timedOut          Boolean     @default(false)
  timeSpentSeconds  Int?
  pointsAwarded     Int         @default(0)
  createdAt         DateTime    @default(now())
  session           QcmSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question          QcmQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionId])
}

model QcmResult {
  id               String     @id @default(cuid())
  sessionId        String     @unique
  companyId        String
  score            Float
  passed           Boolean
  weightedScore    Float?
  correctAnswers   Int
  totalQuestions   Int
  timedOutQuestions Int       @default(0)
  interruptionCount Int       @default(0)
  details          Json?
  createdAt        DateTime   @default(now())
  session          QcmSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
}

model QcmInterruption {
  id             String     @id @default(cuid())
  sessionId      String
  cause          String
  interruptedAt  DateTime   @default(now())
  resumedAt      DateTime?
  authorizedById String?
  metadata       Json?
  session        QcmSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, interruptedAt])
}

model QcmSetting {
  id                     String      @id @default(cuid())
  companyId              String
  type                   QcmBankType?
  questionCountPerSession Int        @default(10)
  timePerQuestionSeconds Int         @default(60)
  passingScore           Int         @default(80)
  companyCoefficient     Int         @default(1)
  jobCoefficient         Int         @default(2)
  clientSiteCoefficient  Int         @default(3)
  postControlDelayHours  Int?
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
  company                Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, type])
}

model PlanningRequest {
  id                  String         @id @default(cuid())
  companyId           String
  requesterId         String
  controllerId        String?
  agentId             String?
  clientId            String?
  siteId              String?
  title               String
  requestedStart      DateTime
  requestedEnd        DateTime
  preferredTimeWindow String?
  status              PlanningStatus @default(DEMANDE)
  reason              String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  company             Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requester           User           @relation("PlanningRequester", fields: [requesterId], references: [id], onDelete: Restrict)
  controller          User?          @relation("PlanningController", fields: [controllerId], references: [id], onDelete: SetNull)
  agent               Agent?         @relation(fields: [agentId], references: [id], onDelete: SetNull)
  client              Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  site                Site?          @relation(fields: [siteId], references: [id], onDelete: SetNull)
}

model Notification {
  id             String           @id @default(cuid())
  companyId      String?
  userId         String?
  targetRole     Role?
  type           NotificationType
  title          String
  message        String
  readAt         DateTime?
  acknowledgedAt DateTime?
  payload        Json?
  createdAt      DateTime         @default(now())
  company        Company?         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user           User?            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId, userId, readAt])
}

model Report {
  id                    String           @id @default(cuid())
  companyId             String
  controlId             String?
  type                  ReportType
  visibility            ReportVisibility
  title                 String
  fileUrl               String?
  generatedById         String?
  sentToAgent           Boolean          @default(false)
  sentToManager         Boolean          @default(false)
  sentToClient          Boolean          @default(false)
  requestedByClientAt   DateTime?
  approvedFullForClientAt DateTime?
  createdAt             DateTime         @default(now())
  company               Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  control               Control?         @relation(fields: [controlId], references: [id], onDelete: SetNull)
  generatedBy           User?            @relation("ReportGenerator", fields: [generatedById], references: [id], onDelete: SetNull)

  @@index([companyId, type])
}

model PreventionMessage {
  id              String                       @id @default(cuid())
  companyId       String?
  title           String
  theme           String?
  body            String
  question        String
  expectedAnswer  String
  active          Boolean                      @default(true)
  startsAt        DateTime?
  endsAt          DateTime?
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt
  company         Company?                     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  acknowledgements PreventionAcknowledgement[]
}

model PreventionAcknowledgement {
  id        String            @id @default(cuid())
  messageId String
  userId    String
  companyId String?
  answer    String
  validated Boolean           @default(false)
  createdAt DateTime          @default(now())
  message   PreventionMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model MonthlySummary {
  id               String    @id @default(cuid())
  companyId        String
  month            DateTime
  metrics          Json
  analysis         String
  recommendations  String
  pdfUrl           String?
  sentToDirectorAt DateTime?
  createdAt        DateTime  @default(now())
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, month])
}

model AiInsight {
  id             String   @id @default(cuid())
  companyId      String
  scope          String
  inputHash      String
  status         String   @default("SIMULE")
  result         Json?
  disabledReason String?
  createdAt      DateTime @default(now())
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, scope])
}

model ReportTemplate {
  id        String     @id @default(cuid())
  companyId String?
  name      String
  type      ReportType
  body      Json
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  company   Company?   @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String      @id @default(cuid())
  companyId String?
  actorId   String?
  action    AuditAction
  entity    String
  entityId  String?
  before    Json?
  after     Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime    @default(now())
  company   Company?    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actor     User?       @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([entity, entityId])
}

model SyncEvent {
  id          String     @id @default(cuid())
  companyId   String
  userId      String?
  deviceId    String
  status      SyncStatus @default(PENDING)
  entity      String
  entityId    String?
  operation   String
  payload     Json
  error       String?
  createdAt   DateTime   @default(now())
  appliedAt   DateTime?
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
}
