DATABASE_URL="postgresql://sentinelle:sentinelle@localhost:5432/sentinelle?schema=public"
APP_URL="http://localhost:3000"
AUTH_SECRET="changez-moi-avec-une-cle-longue-et-aleatoire"
DEMO_MODE="false"
